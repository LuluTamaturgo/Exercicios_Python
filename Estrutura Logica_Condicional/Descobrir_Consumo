"""
Leia a distância em Km e a quantidade de litros de gasolina consumidos por um carro em um percurso,
calcule o consumo em Km/l e escreva uma mensagem de acordo com as informações abaixo:

< 8 = Venda o Carro!
entre 8 e 14 = Econômico!
> 12 = Super Econômico!

"""

print("Digite a distância percorrida:")
distancia = (float(input()))
print("Digite quantos litros consumidos:")
litros = (float(input()))

consumo = distancia/litros

if consumo < 8:
    print(f"Consumo {consumo}, venda o carro!")
elif (consumo > 8) and (consumo <= 14):
    print(f" Consumo {consumo}, carro econômico!")
else:
    print(f"Consumo {consumo}, carro super econômico")