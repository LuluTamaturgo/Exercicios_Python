"""
Uma empresa vende o mesmo produto para quatro diferentes estados. Casa estado possui uma taxa 
diferente de impostos sobre o produto (MG 7%, SP 12%, RJ 15%, MS 8%). Faça um programa em que  usuário
entre com o valor e o estado destino do produto e o programa retorne o preço final do produto acrescido 
do imposto do estado em que ele será vendido. Se o estado digitado não for válido, mostrar uma msg de erro.
"""

print("Informe o valor do produto:")
valor = (float(input()))
print("Informe o estado:")
estado = input()

if estado == "MG":
    imposto = valor * 7 / 100
    resultado = valor + imposto
elif estado == "SP":
    imposto = valor * 12 / 100
    resultado = valor + imposto
elif estado == "RJ":
    imposto = valor * 15 / 100
    resultado = valor + imposto
elif estado == "MS":
    imposto = valor * 8 / 100
    resultado = valor + imposto
else:
    print("Não vendemos para esse estado!")

print(f"Estado escolhido: {estado}; Valor Final: R$ {resultado} ")