"""
Faça um programa que peça ao usuário para digitar 10 valores e some-os.
"""
soma = 0

print("Usando FOR:")
print("Digite 10 numeros inteiros:")
for qtd in range(1, 11):
    print(f"Informe o número {qtd}: ")
    num = (int(input()))
    soma = soma + num

print(f"A soma dos numeros informados é: {soma}")

print("Usando WHILE:")
resultado = 0
cont = 1

print("Digite 10 numeros inteiros:")

while cont <= 10:
    print(f"Informe o número {cont}: ")
    numero = (int(input()))
    resultado = resultado + numero
    cont = cont + 1
print(f"A soma dos numeros informados é: {resultado}")