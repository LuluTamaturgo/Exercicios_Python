"""
Escreva um programa de ajuda para vendedores. A partir de um valor lido, mostre:
* O total a pagar com desconto de 10%
* O valor de cada parcela,no parcelamento de 3x sem juros
* a comissão do vendedor, no caso da venda ser a vista (5% sobre o valor com desconto)
* a comissão do vendedor, no caso da venda ser parcelada (5% sobre o valor total)
"""

print("Informe o valor da venda : ")
valorVenda = (float(input()))

# calculando o valor do desconto de 10% em cima do valor da venda
desconto10 = valorVenda * 10 / 100
Total_desconto10 = valorVenda - desconto10

# calculando o valor da parcela sem juros
parcela = valorVenda / 3

# calculando a comissão sobre o valor da venda com desconto
comissao_venda_vista = Total_desconto10 * 5 / 100

# calculando a comissão sobre a venda parcelada (valorVenda)
comissao_venda_parc = valorVenda * 5 / 100

print(f"Total a pagar com desconto de 10% =R$ {Total_desconto10:.2f}")
print(f"Valor da parcela (3x sem juros) = R$ {parcela:.2f}")
print(f"Comissão Venda a Vista = R$ {comissao_venda_vista:.2f}")
print(f"Comissão Venda Parcelada = R$ {comissao_venda_parc:.2f}")